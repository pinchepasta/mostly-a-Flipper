+// Provides the "Flipper Zero" main-menu entry that reboots the device into the
+// ESP32 Flipper Zero port living in the ota_0 partition. Mirrors the "Bruce"
+// entry on the Flipper side. See 00_Skills/multi-boot.md in the Flipper repo.
+// This file is created by patchBruce.py / tools/bruce_multiboot.patch.
+#ifndef __FLIPPEROS_MENU_H__
+#define __FLIPPEROS_MENU_H__
+
+#include <MenuItemInterface.h>
+
+class FlipperOsMenu : public MenuItemInterface {
+public:
+    FlipperOsMenu() : MenuItemInterface("Flipper Zero") {}
+
+    void optionsMenu(void);
+    void drawIcon(float scale);
+    bool hasTheme() { return false; }
+    String themePath() { return ""; }
+};
+
+#endif // __FLIPPEROS_MENU_H__
