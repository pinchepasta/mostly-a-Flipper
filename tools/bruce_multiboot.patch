@@ -0,0 +1,53 @@
+// --- Multi-boot add-on (not part of upstream Bruce) ---------------------------
+// "Flipper Zero" main-menu entry: reboots into the Flipper Zero firmware that
+// lives in the ota_0 partition (this firmware lives in ota_1). Created by
+// patchBruce.py / tools/bruce_multiboot.patch in the Flipper repo.
+#include "FlipperOsMenu.h"
+
+#include "core/display.h"
+#include "core/utils.h"
+
+#include <esp_ota_ops.h>
+#include <esp_partition.h>
+
+// The Flipper Zero port is flashed into the ota_0 slot.
+#define FLIPPEROS_TARGET_SUBTYPE ESP_PARTITION_SUBTYPE_APP_OTA_0
+
+static void rebootToFlipperOs(void) {
+    const esp_partition_t *target =
+        esp_partition_find_first(ESP_PARTITION_TYPE_APP, FLIPPEROS_TARGET_SUBTYPE, NULL);
+    if (target == NULL) {
+        displayError("No ota_0 partition.\nNot a multi-boot image.", true);
+        return;
+    }
+    if (esp_ota_set_boot_partition(target) != ESP_OK) {
+        displayError("Could not select\nthe Flipper partition.", true);
+        return;
+    }
+    displayInfo("Rebooting to Flipper Zero...");
+    delay(150);
+    ESP.restart();
+}
+
+void FlipperOsMenu::optionsMenu() {
+    options = {
+        {"Reboot to Flipper", []() { rebootToFlipperOs(); }},
+    };
+    addOptionToMainMenu();
+    loopOptions(options, MENU_TYPE_SUBMENU, "Flipper Zero");
+}
+
+void FlipperOsMenu::drawIcon(float scale) {
+    clearIconArea();
+
+    int r = scale * 8;
+    int w = 6 * r;
+    int h = 4 * r;
+    int x = iconCenterX - w / 2;
+    int y = iconCenterY - h / 2;
+
+    // Body of the "Flipper" — a rounded rectangle with a screen and a dot.
+    tft.fillRoundRect(x, y, w, h, r, bruceConfig.priColor);
+    tft.fillRoundRect(x + r / 2, y + r / 2, w - r, h - 2 * r, r / 2, bruceConfig.bgColor);
+    tft.fillCircle(x + w - r, y + h - r, r / 3, bruceConfig.priColor);
+}
